{
  "manifest_version": 3,
  "name": "TabTidy",
  "version": "0.1.0",
  "description": "用相邻新建标签页和 Tab Board 保持 Chrome 标签页整洁。",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "tabGroups",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TabTidy",
    "default_popup": "popup.html"
  },
  "commands": {
    "new-tab-to-right": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "在当前标签页右侧新建标签页"
    },
    "duplicate-tab-to-right": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "复制当前标签页到右侧"
    },
    "open-tab-board": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "打开 TabTidy 标签页管理面板"
    }
  }
}
